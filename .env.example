# Environment Variables untuk TripHop Map
# Salin file ini menjadi .env dan isi dengan nilai dari Supabase Dashboard

# Supabase Project URL - dari Settings > API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anon Key (public) - dari Settings > API
VITE_SUPABASE_ANON_KEY=your_anon_key_here
